<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".HomeFragment">

    <LinearLayout

        android:id="@+id/root_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/white"
        tools:context=".HomeFragment">

        <!-- HEADER: fixed at top -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/white"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:fontFamily="@font/manropelight"
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/live_bus_tracker"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:fontFamily="@font/interlight"
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/real_time_monitoring"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />

                <!-- Bus id and status row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:fontFamily="@font/interregular"
                            android:id="@+id/tvBusId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/bus08"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:fontFamily="@font/interlight"
                            android:id="@+id/tvRoute"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieLiveBus"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/livebus"
                        android:layout_marginEnd="8dp"/>

                    <TextView

                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_status_pill"

                        android:textColor="@color/green_700"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- thin divider under header -->

        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#34505050"
            android:layout_marginTop="4dp"/>

        <ScrollView
            android:id="@+id/main_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:background="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp">

                <!-- Keep all your cards/content here exactly as before -->
                <!-- GPS & Speed card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"

                    android:background="#2596be"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:strokeColor="#DDDDDD"
                    app:strokeWidth="1dp"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:background="#27E3E3E4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <ImageView
                            app:tint="@color/black"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_gps1"
                            android:contentDescription="@string/gps" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp"
                            android:layout_height="wrap_content">

                            <TextView
                                android:fontFamily="@font/interlight"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lora_tracker"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:fontFamily="@font/interregular"
                                android:id="@+id/tvGpsState"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/connected"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:fontFamily="@font/interlight"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/speed"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:layout_gravity="end" />

                            <TextView
                                android:fontFamily="@font/intermedium"
                                android:id="@+id/tvSpeedVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>


                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Current Route card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="#DDDDDD"
                    app:strokeWidth="1dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/white">

                    <LinearLayout
                        android:background="#27E3E3E4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/current_route"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            app:drawableStartCompat="@drawable/ic_gps" />

                        <!-- Timeline row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <LinearLayout
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center">

                                <View
                                    android:layout_marginTop="8dp"
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/dot_green" />

                                <View
                                    android:layout_width="2dp"
                                    android:layout_height="34dp"
                                    android:layout_marginTop="4dp"
                                    android:background="@color/darkgray" />

                                <com.airbnb.lottie.LottieAnimationView

                                    android:layout_width="32dp"
                                    app:tint="@color/blue_600"
                                    android:layout_height="32dp"
                                    android:layout_marginTop="-4dp"
                                    app:lottie_autoPlay="true"
                                    app:lottie_loop="true"
                                    app:lottie_rawRes="@raw/point"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="8dp">

                                <TextView
                                    android:fontFamily="@font/interregular"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/current_stop"
                                    android:textSize="14sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:fontFamily="@font/intermedium"
                                    android:id="@+id/tvCurrentStop"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/market_square"
                                    android:textStyle="bold"
                                    android:textSize="16sp"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/text_primary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:fontFamily="@font/interregular"
                                    android:text="@string/next_stop"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp" />

                                <TextView
                                    android:fontFamily="@font/intermedium"
                                    android:id="@+id/tvNextStop"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"

                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/text_primary" />

                                <TextView
                                    android:id="@+id/tvEta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/interlight"
                                    android:textColor="@color/blue_600"
                                    android:textSize="12sp" />

                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#34505050"/>

                        <TextView
                            android:id="@+id/destination"
                            android:fontFamily="@font/interregular"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:textSize="14sp"
                            android:textColor="@color/black"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Small info tiles grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="12dp"
                   >

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="#DDDDDD"
                        app:strokeWidth="1dp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/white">

                        <LinearLayout
                            android:background="#27E3E3E4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <ImageView
                                android:importantForAccessibility="no" app:tint="@color/black"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="12dp"
                                android:src="@drawable/fuel" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/interregular"
                                android:text="@string/fuel_level"
                                android:textColor="@color/text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvFuel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/_68"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/text_primary" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/progress_green"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="12dp"
                        app:strokeColor="#DDDDDD"
                        app:strokeWidth="1dp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="8dp"
                       >

                        <LinearLayout
                            android:background="#27E3E3E4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                app:tint="@color/black"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="12dp"
                                android:src="@drawable/ic_gps"/>

                            <TextView
                                android:fontFamily="@font/interregular"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/coordinates"
                                android:textSize="13sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvCoordinates"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:textSize="14sp"
                                android:textColor="@color/black"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- System Alert -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/alert_circle_bg"
                    app:strokeColor="@color/alert_stroke"
                    app:strokeWidth="1dp"
                    android:padding="12dp">

                    <LinearLayout
                        android:baselineAligned="false" android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Icon circle -->
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:foregroundGravity="center"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_alert_circle">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_alert_red"
                                android:contentDescription="@string/alert_icon" />
                        </FrameLayout>


                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAlertTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/system_alert"
                                android:textColor="@color/alert_text"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvAlertBody"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/all_systems_operational_no_issues_detected"
                                android:textColor="@color/alert_subtext"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- bottom padding so last item isn't obscured by nav bars -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp"/>
            </LinearLayout>
        </ScrollView>

    </LinearLayout>


</FrameLayout>

